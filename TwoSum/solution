class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) 
    {
        unordered_map<int, int> map; // value → index

        for (int i = 0; i < nums.size(); i++)
        {
            int needed = target - nums[i];

            // check first
            if (map.find(needed) != map.end())
            {
                return {map[needed], i};
            }

            // then store
            map[nums[i]] = i;
        }

        return {}; // guaranteed one solution, just safety
    }
};

